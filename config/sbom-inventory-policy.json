{
  "description": "Policy for generating and auditing a local CycloneDX-style SBOM inventory for third-party runtime references.",
  "workflow_files": [
    ".github/workflows/ci.yml"
  ],
  "image_files": [
    "docker-compose.yaml",
    "k8s/gke/collector.yaml",
    "k8s/gke/sample-app.yaml"
  ],
  "python_version_file": ".python-version",
  "developer_runtime_doc": "docs/developer-runtime.md",
  "minimum_component_count": 8,
  "minimum_action_count": 2,
  "minimum_image_count": 4,
  "minimum_runtime_count": 2,
  "minimum_source_path_count": 8,
  "minimum_detected_fixtures": 6,
  "expected_components": [
    {
      "bom_ref": "github-action:actions/checkout@v6",
      "type": "application",
      "category": "github-action",
      "name": "actions/checkout",
      "version": "v6",
      "purl": "pkg:github/actions/checkout@v6",
      "source_paths": [
        ".github/workflows/ci.yml"
      ]
    },
    {
      "bom_ref": "github-action:actions/setup-python@v6",
      "type": "application",
      "category": "github-action",
      "name": "actions/setup-python",
      "version": "v6",
      "purl": "pkg:github/actions/setup-python@v6",
      "source_paths": [
        ".github/workflows/ci.yml"
      ]
    },
    {
      "bom_ref": "container:jaegertracing/all-in-one:1.57",
      "type": "container",
      "category": "container-image",
      "name": "jaegertracing/all-in-one",
      "version": "1.57",
      "purl": "pkg:docker/jaegertracing/all-in-one@1.57",
      "source_paths": [
        "docker-compose.yaml"
      ]
    },
    {
      "bom_ref": "container:otel/opentelemetry-collector-contrib:0.112.0",
      "type": "container",
      "category": "container-image",
      "name": "otel/opentelemetry-collector-contrib",
      "version": "0.112.0",
      "purl": "pkg:docker/otel/opentelemetry-collector-contrib@0.112.0",
      "source_paths": [
        "docker-compose.yaml"
      ]
    },
    {
      "bom_ref": "container:otel/opentelemetry-collector-contrib:0.112.0@sha256:2203eea06554f892c765d6eff8069cdf64ae8d4516526d03cab4a70e82775495",
      "type": "container",
      "category": "container-image",
      "name": "otel/opentelemetry-collector-contrib",
      "version": "0.112.0@sha256:2203eea06554f892c765d6eff8069cdf64ae8d4516526d03cab4a70e82775495",
      "purl": "pkg:docker/otel/opentelemetry-collector-contrib@0.112.0?digest=sha256:2203eea06554f892c765d6eff8069cdf64ae8d4516526d03cab4a70e82775495",
      "source_paths": [
        "k8s/gke/collector.yaml"
      ]
    },
    {
      "bom_ref": "container:python:3.12-slim@sha256:090ba77e2958f6af52a5341f788b50b032dd4ca28377d2893dcf1ecbdfdfe203",
      "type": "container",
      "category": "container-image",
      "name": "python",
      "version": "3.12-slim@sha256:090ba77e2958f6af52a5341f788b50b032dd4ca28377d2893dcf1ecbdfdfe203",
      "purl": "pkg:docker/python@3.12-slim?digest=sha256:090ba77e2958f6af52a5341f788b50b032dd4ca28377d2893dcf1ecbdfdfe203",
      "source_paths": [
        "k8s/gke/sample-app.yaml"
      ]
    },
    {
      "bom_ref": "runtime:python@3.12",
      "type": "application",
      "category": "runtime",
      "name": "python",
      "version": "3.12",
      "purl": "pkg:generic/python@3.12",
      "source_paths": [
        ".python-version",
        ".github/workflows/ci.yml"
      ]
    },
    {
      "bom_ref": "runtime:ruby@documented",
      "type": "application",
      "category": "runtime",
      "name": "ruby",
      "version": "documented",
      "purl": "pkg:generic/ruby",
      "source_paths": [
        "docs/developer-runtime.md"
      ]
    }
  ],
  "fixtures": [
    {
      "name": "missing_action_component",
      "mutation": "remove_component",
      "bom_ref": "github-action:actions/setup-python@v6",
      "expected_failed_check": "sbom_component_coverage"
    },
    {
      "name": "missing_image_component",
      "mutation": "remove_component",
      "bom_ref": "container:python:3.12-slim@sha256:090ba77e2958f6af52a5341f788b50b032dd4ca28377d2893dcf1ecbdfdfe203",
      "expected_failed_check": "sbom_component_coverage"
    },
    {
      "name": "duplicate_bom_ref",
      "mutation": "set_component_bom_ref",
      "bom_ref": "runtime:ruby@documented",
      "value": "runtime:python@3.12",
      "expected_failed_check": "cyclonedx_shape"
    },
    {
      "name": "missing_source_path",
      "mutation": "clear_source_paths",
      "bom_ref": "container:jaegertracing/all-in-one:1.57",
      "expected_failed_check": "source_traceability"
    },
    {
      "name": "python_runtime_mismatch",
      "mutation": "set_component_version",
      "bom_ref": "runtime:python@3.12",
      "value": "3.11",
      "expected_failed_check": "runtime_boundary"
    },
    {
      "name": "uninventoried_action_reference",
      "mutation": "append_text",
      "path": ".github/workflows/ci.yml",
      "text": "\n      - uses: third-party/not-in-sbom@v1\n",
      "expected_failed_check": "sbom_component_coverage"
    }
  ]
}
