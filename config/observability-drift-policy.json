{
  "description": "Policy for auditing drift between alerting rules, Grafana dashboard evidence, OpenSLO evidence, and generated runbooks.",
  "required_scenarios": [
    "baseline",
    "cache_miss_storm",
    "dependency_timeout",
    "rollout_regression",
    "collector_queue_pressure"
  ],
  "minimum_alert_rules": 5,
  "minimum_dashboard_panels": 6,
  "minimum_openslo_objective_target": 99.0,
  "required_openslo_links": [
    "alerting_rules",
    "grafana_dashboard",
    "release_readiness",
    "runbooks"
  ],
  "required_severity_by_scenario": {
    "baseline": "page",
    "cache_miss_storm": "ticket",
    "dependency_timeout": "page",
    "rollout_regression": "page",
    "collector_queue_pressure": "page"
  },
  "required_alert_annotations": [
    "summary",
    "description",
    "runbook_url",
    "dashboard_hint"
  ],
  "required_runbook_fields": [
    "owner",
    "trigger",
    "first_checks",
    "mitigation"
  ],
  "drift_fixtures": [
    {
      "name": "missing_alert_scenario",
      "mutation": "remove_alert_scenario",
      "scenario": "dependency_timeout",
      "expected_failed_check": "scenario_contract"
    },
    {
      "name": "missing_dashboard_scenario",
      "mutation": "remove_dashboard_scenario",
      "scenario": "cache_miss_storm",
      "expected_failed_check": "scenario_contract"
    },
    {
      "name": "missing_openslo_scenario",
      "mutation": "remove_openslo_scenario",
      "scenario": "collector_queue_pressure",
      "expected_failed_check": "scenario_contract"
    },
    {
      "name": "missing_runbook_scenario",
      "mutation": "remove_runbook_scenario",
      "scenario": "rollout_regression",
      "expected_failed_check": "scenario_contract"
    },
    {
      "name": "severity_mismatch",
      "mutation": "set_alert_severity",
      "scenario": "cache_miss_storm",
      "severity": "page",
      "expected_failed_check": "alert_metadata_contract"
    }
  ]
}
