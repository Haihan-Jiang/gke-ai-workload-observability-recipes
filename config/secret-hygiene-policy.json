{
  "description": "Policy for auditing committed source, manifests, documentation, and generated evidence for high-confidence secret leaks.",
  "scan_roots": [
    ".github",
    "collector",
    "config",
    "dashboards",
    "demo",
    "docs",
    "k8s",
    "policies",
    "scripts",
    "slos",
    "tests",
    "CONTRIBUTING.md",
    "LICENSE",
    "Makefile",
    "NOTICE",
    "README.md",
    "SECURITY.md",
    "docker-compose.yaml"
  ],
  "excluded_dirs": [
    ".git",
    ".mypy_cache",
    ".pytest_cache",
    "__pycache__",
    "node_modules",
    "out",
    "venv"
  ],
  "max_file_bytes": 1048576,
  "minimum_scanned_files": 150,
  "minimum_evidence_files": 120,
  "minimum_pattern_count": 6,
  "minimum_detected_fixtures": 6,
  "deny_patterns": [
    {
      "name": "private_key_header",
      "severity": "critical",
      "regex": "-----BEGIN (?:RSA |EC |OPENSSH |DSA |)?PRIVATE KEY-----"
    },
    {
      "name": "aws_access_key_id",
      "severity": "critical",
      "regex": "AKIA[0-9A-Z]{16}"
    },
    {
      "name": "google_api_key",
      "severity": "critical",
      "regex": "AIza[0-9A-Za-z_-]{35}"
    },
    {
      "name": "github_token",
      "severity": "critical",
      "regex": "gh[pousr]_[A-Za-z0-9_]{36,}"
    },
    {
      "name": "slack_webhook",
      "severity": "critical",
      "regex": "https://hooks\\.slack\\.com/services/[A-Za-z0-9+/]{8,}/[A-Za-z0-9+/]{8,}/[A-Za-z0-9+/]{20,}"
    },
    {
      "name": "slack_token",
      "severity": "critical",
      "regex": "xox[baprs]-[0-9A-Za-z-]{20,}"
    }
  ],
  "fixtures": [
    {
      "name": "private_key_header_fixture",
      "mutation": "append_synthetic_secret",
      "path": "README.md",
      "pattern_name": "private_key_header",
      "expected_failed_check": "secret_pattern_scan"
    },
    {
      "name": "aws_access_key_fixture",
      "mutation": "append_synthetic_secret",
      "path": "README.md",
      "pattern_name": "aws_access_key_id",
      "expected_failed_check": "secret_pattern_scan"
    },
    {
      "name": "google_api_key_fixture",
      "mutation": "append_synthetic_secret",
      "path": "README.md",
      "pattern_name": "google_api_key",
      "expected_failed_check": "secret_pattern_scan"
    },
    {
      "name": "github_token_fixture",
      "mutation": "append_synthetic_secret",
      "path": "README.md",
      "pattern_name": "github_token",
      "expected_failed_check": "secret_pattern_scan"
    },
    {
      "name": "slack_webhook_fixture",
      "mutation": "append_synthetic_secret",
      "path": "README.md",
      "pattern_name": "slack_webhook",
      "expected_failed_check": "secret_pattern_scan"
    },
    {
      "name": "slack_token_fixture",
      "mutation": "append_synthetic_secret",
      "path": "README.md",
      "pattern_name": "slack_token",
      "expected_failed_check": "secret_pattern_scan"
    }
  ]
}
